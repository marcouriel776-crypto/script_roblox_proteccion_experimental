-- ================= PROTECTION =================

local LastPos = Vector3.zero
local LastTick = tick()

Connections.Heartbeat = RunService.Heartbeat:Connect(function(dt)
    if not ScriptRunning then return end

    -- FPS
    local fps = math.floor(1 / dt)
    local status = ProtectionEnabled and "ACTIVE" or "OFF"
    Info.Text = "FPS: "..fps.." | Status: "..status

    if not ProtectionEnabled then
        LastPos = RootPart.Position
        return
    end

    -- Anti-Velocity / Force
    local dist = (RootPart.Position - LastPos).Magnitude
    if dist > 35 then
        RootPart.AssemblyLinearVelocity = Vector3.zero
        RootPart.AssemblyAngularVelocity = Vector3.zero
        RootPart.CFrame = CFrame.new(LastPos)
        BlockedEvents += 1
        Counter.Text = "Blocked Events: "..BlockedEvents
    end

    -- Safe Client: remove abusive forces
    for _, v in pairs(RootPart:GetChildren()) do
        if v:IsA("BodyVelocity") or v:IsA("LinearVelocity") or v:IsA("BodyAngularVelocity") then
            v:Destroy()
            BlockedEvents += 1
            Counter.Text = "Blocked Events: "..BlockedEvents
        end
    end

    LastPos = RootPart.Position
end)
