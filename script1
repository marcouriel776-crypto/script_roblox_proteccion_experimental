-- Collision Groups (reuse if exists)
pcall(function() PhysicsService:CreateCollisionGroup("DangerPlayer") end)
pcall(function() PhysicsService:CollisionGroupSetCollidable("DangerPlayer", "LocalPlayerGroup", false) end)

local function MarkDangerous(plr)
    DangerousPlayers[plr] = tick()
    FlingDetected = true
    FlingCount += 1
end

local function CleanupDangerous()
    for plr, t in pairs(DangerousPlayers) do
        if tick() - t > 3 then
            DangerousPlayers[plr] = nil
        end
    end
    if next(DangerousPlayers) == nil then
        FlingDetected = false
    end
end

-- Assign collision only to dangerous players
local function ApplySmartCollision()
    if not NoPlayerCollision or not SmartEnabled then return end

    for plr in pairs(DangerousPlayers) do
        if plr.Character then
            for _, part in ipairs(plr.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    PhysicsService:SetPartCollisionGroup(part, "DangerPlayer")
                end
            end
        end
    end
end

-- Detector Loop (lightweight)
Connections.SmartHeartbeat = RunService.Heartbeat:Connect(function()
    if not ScriptRunning then return end

    CleanupDangerous()

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local vel = hrp.AssemblyLinearVelocity.Magnitude
                if vel > (SmartMode == "SAFE" and 80 or 120) then
                    MarkDangerous(plr)
                end

                for _, v in ipairs(hrp:GetChildren()) do
                    if v:IsA("BodyVelocity") or v:IsA("LinearVelocity") then
                        MarkDangerous(plr)
                    end
                end
            end
        end
    end

    ApplySmartCollision()

    SmartLabel.Text = FlingDetected
        and ("⚠ Fling Detected | Events: "..FlingCount)
        or "Smart Protection: CLEAR"
end)
